# ─────────────────────────────────────────────────────────────
# HR Management System — 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
# ─────────────────────────────────────────────────────────────

# ─── データベース ──────────────────────────────────────────────
# PostgreSQL 16 接続文字列
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hr_management?schema=public"

# Prisma Shadow DB（マイグレーション用）
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hr_management_shadow?schema=public"

# DB 暗号化シークレット（pgp_sym_encrypt 用）
DB_ENCRYPTION_SECRET="change-me-to-a-secure-random-string-32chars"

# ブラインドインデックス HMAC シークレット（emailHash / employeeCodeHash 用）
BLIND_INDEX_SECRET="change-me-to-another-secure-random-string-32chars"

# ─── Redis ────────────────────────────────────────────────────
# Redis 7 接続文字列（セッション・レート制限・BullMQ・AIキャッシュ共用）
REDIS_URL="redis://localhost:6379"

# ─── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-secure-random-string-for-nextauth"

# ─── AI プロバイダ ─────────────────────────────────────────────
# "anthropic" | "openai" のどちらかを指定
AI_PROVIDER="anthropic"

# Anthropic Claude API（主）
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI API（フォールバック）
OPENAI_API_KEY="sk-..."

# AI レスポンスキャッシュ TTL（秒、デフォルト 300 = 5分）
AI_CACHE_TTL_SECONDS="300"

# AI 月次予算（USD）— 80% で WARN、100% で CRITICAL
AI_MONTHLY_BUDGET_USD="100"

# ─── メール（Resend） ──────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@example.com"

# ─── アプリケーション ──────────────────────────────────────────
# "development" | "test" | "production"
NODE_ENV="development"

# アプリケーション URL（通知メールのリンク生成に使用）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 開発専用: 認証バイパス（画面確認用）
# true にすると development 環境でダミーセッションを返す
DEV_AUTH_BYPASS="false"
DEV_AUTH_ROLE="ADMIN"
DEV_AUTH_USER_ID="dev-user-1"
DEV_AUTH_SESSION_ID="dev-session-1"
DEV_AUTH_EMAIL="dev-admin@example.com"
DEV_AUTH_NAME="Development User"

# ─── ストレージ（CSV/PDF エクスポート） ───────────────────────────
# S3 互換ストレージ（AWS S3 または Cloudflare R2）
STORAGE_ENDPOINT="https://s3.amazonaws.com"
STORAGE_REGION="ap-northeast-1"
STORAGE_BUCKET="hr-management-exports"
STORAGE_ACCESS_KEY_ID="your-access-key-id"
STORAGE_SECRET_ACCESS_KEY="your-secret-access-key"

# 署名付き URL の有効期限（秒、デフォルト 86400 = 24時間）
STORAGE_SIGNED_URL_EXPIRES="86400"
